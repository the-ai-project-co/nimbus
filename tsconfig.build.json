{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false
  },
  "exclude": [
    "node_modules",
    "src/__tests__",
    "src/build.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
